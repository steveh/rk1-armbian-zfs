# Copy to secrets.env and fill in. secrets.env is gitignored.
# Consumed by userpatches/customize-image.sh at build time and substituted
# into /boot/user-data.

# Login user created by cloud-init.
RK1_USER=steve

# Hashed password for RK1_USER. Generate with:
#   mkpasswd -m sha-512
# or:
#   openssl passwd -6
# Leave empty to disable password login for this user.
RK1_USER_PASSWORD_HASH='$6$REPLACE_ME$REPLACE_ME'

# Hashed password for root. Same generation. Leave empty to keep root locked.
RK1_ROOT_PASSWORD_HASH=''

# Authorized SSH keys for RK1_USER, one per line. Heredoc-friendly.
RK1_USER_SSH_KEYS='ssh-ed25519 AAAA... user@host
ssh-ed25519 AAAA... other@host'
