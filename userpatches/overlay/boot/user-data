#cloud-config

hostname: rk1

users:
  - default

# Disable cloud-init's own package handling; we do it explicitly in runcmd.ci.sh.
package_update: false
package_upgrade: false

# Pre-grow rootfs on eMMC, then hand off to runcmd.ci.sh.
runcmd:
  - [ cloud-init-per, once, resize_part, growpart, /dev/mmcblk0, '1' ]
  - |
    export LC_ALL=C LANG=C
    PS4="runcmd: "; set -ex
    : "decouple from systemd cgroup so we are not killed when cloud-final exits"
    echo $$ > /sys/fs/cgroup/cgroup.procs
    (
      while ! systemctl is-active --quiet cloud-final.service \
           && ! systemctl show -p SubState --value cloud-final.service | grep -q exited; do
        sleep 5
      done
      cloud-init clean
      while ! ping -c1 -W2 deb.debian.org >/dev/null 2>&1; do sleep 3; done
      for i in 1 2 3; do apt-get update && break; sleep $((i*3)); done
      if [ -r /boot/runcmd.ci.sh ]; then
        sh -eu /boot/runcmd.ci.sh
      fi
    ) &
