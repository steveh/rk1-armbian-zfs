#cloud-config

hostname: rk1

# Substituted from secrets.env at build time. If secrets.env was absent,
# customize-image.sh leaves placeholders in place — the system will boot
# with no preseeded login.

users:
  - name: __RK1_USER__
    groups: [sudo, adm, systemd-journal]
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: false
    hashed_passwd: '__RK1_USER_PASSWORD_HASH__'
    ssh_authorized_keys:
__RK1_USER_SSH_KEYS_YAML__
  - name: root
    lock_passwd: false
    ssh_authorized_keys:
__RK1_USER_SSH_KEYS_YAML__

chpasswd:
  expire: false
  users:
    - {name: root, password: '__RK1_ROOT_PASSWORD_HASH__', type: hash}

ssh_pwauth: true
disable_root: false

# Disable cloud-init's own package handling; we do it explicitly in runcmd.ci.sh.
package_update: false
package_upgrade: false

# Pre-grow rootfs on eMMC, then hand off to runcmd.ci.sh.
runcmd:
  - [ cloud-init-per, once, resize_part, growpart, /dev/mmcblk0, '1' ]
  - |
    export LC_ALL=C LANG=C
    PS4="runcmd: "; set -ex
    : "decouple from systemd cgroup so we are not killed when cloud-final exits"
    echo $$ > /sys/fs/cgroup/cgroup.procs
    (
      exec >/var/log/rk1-firstboot.log 2>&1
      echo "rk1-firstboot: started at $(date -u +%FT%TZ)"
      while ! systemctl is-active --quiet cloud-final.service \
           && ! systemctl show -p SubState --value cloud-final.service | grep -q exited; do
        sleep 5
      done
      cloud-init clean
      while ! ping -c1 -W2 deb.debian.org >/dev/null 2>&1; do sleep 3; done
      for i in 1 2 3; do apt-get update && break; sleep $((i*3)); done
      if [ -r /boot/runcmd.ci.sh ]; then
        sh -eux /boot/runcmd.ci.sh
      fi
      echo "rk1-firstboot: finished at $(date -u +%FT%TZ)"
    ) &
# vim: ft=yaml sw=2 ts=2 et
